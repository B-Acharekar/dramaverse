<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.DramaX" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">#000000</item>
        <item name="android:navigationBarColor">#000000</item>
        <item name="android:statusBarColor">#000000</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.DramaX.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#000000</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/icon_2_launcher</item>
        <item name="windowSplashScreenIconBackgroundColor">#000000</item>
        <item name="postSplashScreenTheme">@style/Theme.DramaX</item>
    </style>
</resources>
